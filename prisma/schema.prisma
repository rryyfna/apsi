generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MAHASISWA
  DOSEN
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique // Berfungsi sebagai NIM/NIDN/NIP
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  
  mahasiswa Mahasiswa?
  dosen     Dosen?
}

model Mahasiswa {
  id           String @id @default(cuid())
  userId       String @unique
  nim          String @unique
  name         String
  fakultas     String?
  programStudi String?
  user         User   @relation(fields: [userId], references: [id])
  
  enrollments  Enrollment[]
}

model Dosen {
  id     String @id @default(cuid())
  userId String @unique
  nidn   String @unique
  name   String
  user   User   @relation(fields: [userId], references: [id])
  
  kelas  Kelas[]
}

model MataKuliah {
  id            String @id @default(cuid())
  kodeMk        String @unique
  namaMk        String
  sks           Int
  semester      Int?
  isNonTeaching Boolean @default(false)
  
  kelas         Kelas[]
  cplMappings   CourseCPLMapping[]
}

model Kelas {
  id                   String @id @default(cuid())
  mataKuliahId         String
  dosenId              String
  namaKelas            String // A, B, C, dsb
  kuotaReguler         Int    @default(0)
  jumlahAmbilReguler   Int    @default(0)
  
  mataKuliah           MataKuliah @relation(fields: [mataKuliahId], references: [id])
  dosen                Dosen      @relation(fields: [dosenId], references: [id])
  enrollments          Enrollment[]
  
  @@unique([mataKuliahId, namaKelas])
}

model Enrollment {
  id               String @id @default(cuid())
  mahasiswaId      String
  kelasId          String
  
  nilaiTugas       Float?
  nilaiUts         Float?
  nilaiUas         Float?
  nilaiPartisipasi Float?
  nilaiProyek      Float?
  nilaiAkhir       Float?
  huruf            String?
  
  mahasiswa        Mahasiswa @relation(fields: [mahasiswaId], references: [id])
  kelas            Kelas     @relation(fields: [kelasId], references: [id])
  
  nonTeachingTemplateId String?
  nonTeachingTemplate   NonTeachingGradeTemplate? @relation(fields: [nonTeachingTemplateId], references: [id])
  nonTeachingScores     NonTeachingGradeScore[]
  
  @@unique([mahasiswaId, kelasId])
}

model CPL {
  id          String @id @default(cuid())
  kode        String @unique // e.g., CPL-1, CPL-2
  deskripsi   String
  
  mappings    CourseCPLMapping[]
}

model CourseCPLMapping {
  id           String @id @default(cuid())
  mataKuliahId String
  cplId        String
  ukName       String // e.g., "UK1", "UK2" -> maps to Tugas, UTS...
  threshold    Float  // The minimum score to pass this CPL
  
  mataKuliah   MataKuliah @relation(fields: [mataKuliahId], references: [id], onDelete: Cascade)
  cpl          CPL        @relation(fields: [cplId], references: [id], onDelete: Cascade)
  
  @@unique([mataKuliahId, cplId, ukName])
}

model NonTeachingGradeTemplate {
  id           String @id @default(cuid())
  nama         String // e.g., "Template Skripsi"
  
  components   NonTeachingGradeComponent[]
  enrollments  Enrollment[]
}

model NonTeachingGradeComponent {
  id           String @id @default(cuid())
  templateId   String
  namaKriteria String // e.g., "Nilai Pembimbing", "Nilai Penguji"
  bobot        Float  // Percentage, must sum to 100 per template
  
  template     NonTeachingGradeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  scores       NonTeachingGradeScore[]
}

model NonTeachingGradeScore {
  id           String @id @default(cuid())
  enrollmentId String
  componentId  String
  nilai        Float
  
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  component    NonTeachingGradeComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  
  @@unique([enrollmentId, componentId])
}
